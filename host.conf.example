# bbl-ch-build host.conf — shared secrets template.
#
# Operator copies this to /etc/bbl-ch.host.conf (mode 600) and fills
# in real values. NEVER commit a populated copy.
#
# The provision script auto-derives /etc/bbl-ch-<short>.host.conf
# from this shared file and adds BBL_DOMAIN at the time of provision.

# ── Django code source ──
# BBL_DJANGO_BRANCH=release tracks the moveable ref pushed to bbl-django
# origin pointing at the currently-tested-on-beta tip. Operator advances
# this ref to roll out new code; ch-atl* boxes pick it up via re-running
# step 03-django-clone.sh OR via cron-tracked auto-update if configured.────────────────────────────────────────────
# bbl-django repo + branch to deploy. Default to the merged django-upgrade
# tip on master once chb-atl's branch is merged.
BBL_DJANGO_REPO=git@github.com:bblv2/bbl-django.git
BBL_DJANGO_BRANCH=release

# ── Frontend SPA source ─────────────────────────────────────────────
# bblfrontend repo + git ref to check out. The ref should point at a
# committed copy of the prod-tested /opt/bblfrontend/build/ — see
# project_bbl_frontend_layout memory.
#
# Workflow before first ch-atl3 provision: on ch-atl1 commit the current
# build/ to git, push as tag e.g. prod-2026-05-03, then set BBL_FRONTEND_REF
# below to that tag. Avoids rsync; avoids re-building on the new host.
BBL_FRONTEND_REPO=git@github.com:bblv2/bblfrontend.git
BBL_FRONTEND_REF=prod-2026-05-03

# ── Django runtime secrets ──────────────────────────────────────────
# These get baked into the rendered Django settings file at provision time.
# Source of truth: copy from ch-atl1's current settings (verify with:
# grep -E '^(SECRET_KEY|DATABASES|REDIS|STRIPE|MAILGUN|TELNYX)' on ch-atl1).
BBL_DJANGO_SECRET_KEY=
BBL_DB_HOST=lb-atl.bblapp.io
BBL_DB_PORT=5432
BBL_DB_NAME=bbl2022
BBL_DB_USER=bbldbuser
BBL_DB_PASSWORD=
BBL_REDIS_URL=redis://lb-atl.bblapp.io:6379/0
BBL_STRIPE_SECRET_KEY=
BBL_STRIPE_PUBLIC_KEY=
BBL_STRIPE_WEBHOOK_SECRET=
BBL_MAILGUN_API_KEY=
BBL_MAILGUN_DOMAIN=
BBL_TELNYX_USER=
BBL_TELNYX_TOKEN=
# Telnyx V2 API key (Bearer auth — separate from V1 USER/TOKEN above).
# Used by cutover.sh and any V2 API automation. Find via: portal → Auth → API Keys.
BBL_TELNYX_API_KEY=
BBL_BUGCATCHER_DSN=

# ── TLS cert ────────────────────────────────────────────────────────
# Email used for Let's Encrypt account; expiration warnings go here.
BBL_CERT_EMAIL=

# ── Monitor registration ────────────────────────────────────────────
# bbl-monitor token for /api/hosts/register endpoint (ch-atl3 needs to
# show up on https://monitor.rpt.bblapp.io/servers automatically).
# Same token bbl-fs-build uses.
BBL_MONITOR_TOKEN=

# ── Per-host runtime tuning (optional; defaults shown) ─────────────
# Gunicorn bind address. lb-atl proxies to this. Default 127.0.0.1:8001
# matches chb-atl convention; use 0.0.0.0:8001 if lb-atl is on a different
# subnet (legacy ch-atl1 used 0.0.0.0).
# BBL_GUNICORN_BIND=127.0.0.1:8001

# Number of gunicorn workers. chb-atl runs 9; ch-atl1 runs 10.
# BBL_GUNICORN_WORKERS=9

# Whether THIS host runs celery beat (-B). Defaults FALSE because most
# new boxes are added to a pool where another box already runs beat —
# enabling beat on two boxes double-fires scheduled tasks (billing
# cleanups, customer emails, churn reports). Operator flips to true
# AFTER decommissioning the old box.
# BBL_RUN_BEAT=false

# Extra DNS aliases nginx should accept (space-separated). Always-on:
# BBL_HOSTNAME (auto-set during provision).
# BBL_DOMAIN_ALIASES=app.brandedbridgeline.com beta.bblapp.io

# ── Deployment role ─────────────────────────────────────────────────
# BBL_ROLE=prod   Production CH (lb-atl pool, serves app.brandedbridgeline.com)
# BBL_ROLE=beta   Beta CH (lbb-atl pool, serves beta.bblapp.io)
# Determines SESSION_COOKIE_DOMAIN default (prod→.brandedbridgeline.com, beta→.bblapp.io).
# Override BBL_SESSION_COOKIE_DOMAIN explicitly for unusual setups.
# BBL_ROLE=prod
# BBL_SESSION_COOKIE_DOMAIN=.brandedbridgeline.com

# ── Switchboard debug logging ───────────────────────────────────────
# Set to "true" to wrap every FS-facing switchboard view (RING, PIN_INPUT,
# WAIT, FLOOR_SPEAKER_EVENT, etc.) with the dashed-banner debug decorator
# (request POST + rendered XML to stderr). Default off — verbose. Useful
# for diagnosing call-flow regressions on a freshly-provisioned beta CH.
# BBL_DEBUG_SWITCHBOARD=true

# ── /call-trace Redis dual-write ────────────────────────────────────
# rpt-side Redis URL for the bbl:trace stream consumed by bbl-monitor
# /call-trace. Django's switchboard views XADD a per-request event with
# the rendered XML body so the UI can show the relay↔Django dialog.
# Empty / unset = dual-write disabled (safe default; relay-side events
# still reach the stream from esl_outbound, but XML won't render in the
# timeline because there's no django-side counterpart).
# BBL_REDIS_TRACE_URL=redis://:PASSWORD@45.79.211.163:6379/0
